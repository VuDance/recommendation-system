pipeline {
    agent any

    options {
        buildDiscarder(logRotator(numToKeepStr: '5')) // Giảm số lượng giữ lại để tránh đầy 12GB /var/lib/jenkins
        timeout(time: 1, unit: 'HOURS')
        timestamps()
    }

    environment {
        JDK_HOME = tool 'Java17'
        M3_HOME = tool 'Maven3'
        
        // Gán trực tiếp vào JAVA_HOME
        JAVA_HOME = "${JDK_HOME}"
        
        // Đưa bin của Java 17 lên ĐẦU của env.PATH
        PATH = "${JDK_HOME}/bin:${M3_HOME}/bin:${env.PATH}"
    }

    stages {
        stage('Checkout') {
            steps {
                echo '=== Pulling source code ==='
                checkout scm
            }
        }

        stage('Verify Environment') {
            steps {
                script {
                    // Bước này cực kỳ quan trọng để debug
                    sh 'echo "JAVA_HOME is: $JAVA_HOME"'
                    sh 'java -version'
                    sh 'mvn -version'
                }
            }
        }

        stage('Maven Build & Package') {
            steps {
                dir('flink') {
                    script {
                        sh 'mvn clean package -DskipTests -q'
                        // Thêm dòng này để kiểm tra file đã tồn tại chưa
                        sh 'ls -l target/' 
                    }
                }
            }
        }

        stage('Deploy with Docker Compose') {
            steps {
                dir('flink') {
                    script {
                        echo '=== Starting services with Docker Compose ==='
                        // --build: Đảm bảo build lại nếu có thay đổi trong config
                        // -d: Chạy ngầm
                        // --remove-orphans: Xóa các container cũ không còn trong file config
                        sh 'docker compose up -d --remove-orphans'
                        
                        echo '=== Service Status ==='
                        sh 'docker compose ps'
                    }
                }
            }
        }

    }

    post {
        always {
            script {
                echo '=== Cleaning up Docker layers ==='
                // Xóa các image "dangling" (image rác phát sinh khi build đè tag)
                sh 'docker image prune -f'
            }
        }
        success {
            echo '=== DEPLOY SUCCESSFUL ==='
        }
        failure {
            echo '=== DEPLOY FAILED ==='
        }
        cleanup {
            script {
                echo '=== Clearing Workspace ==='
                // Xóa sạch workspace sau khi xong để giải phóng dung lượng đĩa
                cleanWs() 
            }
        }
    }
}