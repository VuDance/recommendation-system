pipeline {
    agent any

    options {
        buildDiscarder(logRotator(numToKeepStr: '5')) // Giảm số lượng build để tiết kiệm 12GB của bạn
        timeout(time: 1, unit: 'HOURS')
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    echo '=== Pulling latest code from GitHub ==='
                    checkout scm
                }
            }
        }

        stage('Deploy with Docker Compose') {
            steps {
                // Chui vào folder chứa docker-compose.yml
                dir('ai-model') {
                    script {
                        echo '=== Re-deploying application on local EC2 ==='
                        
                        // --build: Đảm bảo build lại image mới nếu code có thay đổi
                        // -d: Chạy ngầm (detached mode)
                        // --remove-orphans: Dọn dẹp các container thừa không định nghĩa trong file
                        sh 'docker-compose up --build -d --remove-orphans'
                        
                        echo '=== Deployment Status ==='
                        sh 'docker-compose ps'
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                echo '=== System Cleanup ==='
                // Xóa các image cũ, dangling layers để tránh đầy ổ cứng (vấn đề 86% của bạn)
                sh 'docker image prune -f'
            }
        }
        success {
            echo '=== Deployment Successful! ==='
        }
        failure {
            echo '=== Deployment Failed. Check logs above. ==='
        }
        cleanup {
            script {
                echo '=== Cleaning Jenkins Workspace ==='
                cleanWs() // Xóa sạch code sau khi build để giải phóng dung lượng cho /var/lib/jenkins
            }
        }
    }
}