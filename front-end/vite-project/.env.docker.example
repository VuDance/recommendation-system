# Frontend Docker Compose Environment Variables
# Copy this file to .env and adjust values for your deployment.

# API URL for backend service
# When running with Docker Compose, you can set this to the service name if backend is in same compose
# Example: http://backend:8080
VITE_API_URL=http://localhost:8080

# Docker image tag (optional)
# DOCKER_IMAGE_TAG=latest

# Docker registry (optional)
# DOCKER_REGISTRY=docker.io
# DOCKER_IMAGE_NAME=yourusername/recommendation-frontend