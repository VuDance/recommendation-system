pipeline {
    agent any

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 1, unit: 'HOURS')
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    echo '=== Checking out source code ==='
                    checkout scm
                }
            }
        }

        stage('Prepare Env File') {
            steps {
                withCredentials([file(credentialsId: 'env-front-end', variable: 'ENV_FILE')]) {
                    sh 'cp $ENV_FILE front-end/vite-project/.env'
                }
            }
        }

        stage('Deploy with Docker Compose') {
            steps {
                dir('front-end/vite-project') {
                    script {
                        echo '=== Removing old containers and images ==='
                        sh 'docker stop frontend || true'
                        sh 'docker rm -f frontend || true'
                        sh 'docker rmi -f $(docker images --format "{{.Repository}}:{{.Tag}}" | grep frontend) || true'
                        sh 'docker compose down --rmi all || true'

                        echo '=== Rebuilding and Starting services ==='
                        sh 'docker compose up -d --build --remove-orphans'

                        echo '=== Service Status ==='
                        sh 'docker compose ps'

                        echo '=== Application Logs (last 50 lines) ==='
                        sh 'docker logs --tail 50 frontend || true'
                    }
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    sleep 10
                    sh '''
                        curl -s http://localhost:3000 || echo "Frontend health check failed"
                    '''
                }
            }
        }

    }

    post {
        always {
            script {
                echo '=== Cleaning up ==='
                // Clean Docker build context
                sh 'docker image prune -f'
                sh 'rm -f front-end/vite-project/.env'
            }
        }

        success {
            script {
                echo '=== Build succeeded ==='
            }
        }

        failure {
            script {
                echo '=== Build failed ==='
            }
        }

        unstable {
            script {
                echo '=== Build is unstable ==='
            }
        }

        cleanup {
            script {
                echo '=== Final cleanup ==='
                // Clean workspace
                cleanWs()
            }
        }
    }
}